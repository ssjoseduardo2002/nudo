{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "../dist/out-tsc/app",
    "types": [],
    "composite": false,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  },
  "files": [
    "main.ts"
  ],
  "include": [
    "**/*.d.ts",
    "**/*.ts"
  ],
  "exclude": [
    "**/*.spec.ts"
  ]
}
  