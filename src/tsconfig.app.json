{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "../dist/out-tsc/app",
    "types": [],
    // ⚡ BLINDAJE EXTRA: Asegura que el compilador no ignore decoradores
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "files": [
    "main.ts"
  ],
  "include": [
    "src/**/*.d.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "src/test.ts"
  ]
}
  